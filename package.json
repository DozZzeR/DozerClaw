{
  "name": "dozerclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "node --env-file-if-exists=.env --import tsx src/main.ts",
    "dev:health": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-health.ts",
    "dev:codex-smoke": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-codex-smoke.ts",
    "dev:delete-subject-alias": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-delete-subject-alias.ts",
    "dev:google-oauth": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-google-oauth.ts",
    "dev:mempalace-smoke": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-mempalace-smoke.ts",
    "dev:list-subject-aliases": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-list-subject-aliases.ts",
    "dev:register-services": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-register-services.ts",
    "dev:store-file": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-store-file.ts",
    "dev:google-drive-smoke": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-google-drive-smoke.ts",
    "dev:subject-alias": "node --env-file-if-exists=.env --import tsx src/entrypoints/cli/dev-subject-alias.ts",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "dev:telegram": "node --env-file-if-exists=.env --import tsx src/main.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
