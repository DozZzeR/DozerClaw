NODE_ENV=development

# Runtime storage
DOZERCLAW_DB_PATH=data/dozerclaw.sqlite
DOZERCLAW_FILE_STORAGE_ROOT=data/file-inbox

# Telegram bot runtime
DOZERCLAW_TELEGRAM_BOT_TOKEN=your_bot_token
DOZERCLAW_TELEGRAM_OWNER_USER_ID=your_numeric_telegram_user_id
DOZERCLAW_TELEGRAM_POLL_TIMEOUT_SECONDS=30

# Codex model provider
DOZERCLAW_MODEL_ROUTING_ENABLED=false
DOZERCLAW_CODEX_MODEL=gpt-5.5
DOZERCLAW_CODEX_TIMEOUT_MS=120000
DOZERCLAW_CODEX_PROJECT_ROOT=.
DOZERCLAW_CODEX_TMP_DIR=data/tmp/codex

# Local development message harness
DOZERCLAW_DEV_PROVIDER=dev
DOZERCLAW_DEV_OWNER_USER_ID=owner
DOZERCLAW_DEV_OWNER_CHAT_ID=owner-private
DOZERCLAW_DEV_OWNER_NAME=Owner
DOZERCLAW_DEV_MESSAGE_TEXT=health

# Local file storage harness
DOZERCLAW_DEV_FILE_PATH=
DOZERCLAW_DEV_FILE_MIME_TYPE=

# Local service registration harness
DOZERCLAW_SERVICE_HEALTH_TIMEOUT_MS=1000
DOZERCLAW_TASKFRAME_HEALTH_URL=http://127.0.0.1:4120/health
DOZERCLAW_MEMPALACE_HTTP_HEALTH_URL=http://127.0.0.1:4118/healthz
