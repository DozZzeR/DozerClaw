  "version": 1,
  "defaults": {
    "storage": "google_drive",
    "rootFolderEnv": "DOZERCLAW_GOOGLE_DRIVE_UPLOAD_FOLDER_ID",
    "placementConfirmation": "disabled"
  },
  "modelGuidance": {
    "languagePolicy": [
      "Keep path, description, examples, and aliases in the user language because they are user-facing Drive and search signals.",
      "Keep slug, documentTypes, subjects, and future technical keys in English snake_case because they are stable machine identifiers."
    ],
    "folderSelection": [
      "Prefer the deepest existing folder whose description, aliases, examples, documentTypes, and subjects match the file and the user message.",
      "Use documentTypes and subjects as structured hints, not as the only source of truth.",
      "When confidence is low, upload to the configured Drive root and record search metadata instead of forcing a weak folder choice.",
      "For normal uploads, do not ask placement confirmation while placementConfirmation is disabled."
    ],
    "newFolderProposal": [
      "Do not create new policy folders during normal single-file upload unless the owner explicitly asks to create that folder.",
      "During legacy Drive cleanup, propose a new folder when several files form a recurring cluster that does not fit existing folders.",
      "A proposal must include parentPath, proposed path in Russian, slug in English snake_case, description, documentTypes, subjects, aliases, examples, confidence, and rationale.",
      "If the file belongs to a temporary one-off topic, prefer Разное_и_Архив or the closest existing archive folder over adding a new folder."
    ],
    "cleanupMode": [
      "First register and describe existing Drive files without moving them.",
      "Infer candidate folders and confidence for each file, then group uncertain files for owner review.",
      "Only after the policy is updated should a later migration step move files into created folders."
    ]
  },
